<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Programmerare.ShortestPaths.Adaptee.Bsmock</RootNamespace>
    <Version>1.0.0</Version>
    <Description>Library used for finding the shortest paths between two nodes in a graph.
The project was created from a fork of a Java library which has been translated to C#.
The original Java library:
https://github.com/bsmock/k-shortest-paths/
The Java fork of the above Java library:
https://github.com/TomasJohansson/k-shortest-paths</Description>
    <AssemblyName>Programmerare.ShortestPaths.Adaptee.Bsmock</AssemblyName>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DocumentationFile>.\bin\Programmerare.ShortestPaths.Adaptee.Bsmock.xml</DocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OptimizedPriorityQueue" Version="5.1.0" />
  </ItemGroup>

</Project>
